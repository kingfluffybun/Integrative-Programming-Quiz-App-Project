<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Express Quiz App' %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/">Home</a> | <a href="/quiz">Quiz</a> |
        <a href="/about">About</a>
      </nav>
    </header>
    <div class="container">
      <h1><%= title || 'Express Quiz App' %></h1>
      <p style="text-align: center; color: #666">
        Test your knowledge with questions from the Open Trivia Database!
      </p>

      <div class="quiz-controls">
        <div class="form-group">
          <label for="amount">Number of Questions:</label>
          <input type="number" id="amount" min="1" max="50" value="5" />
        </div>
        <div class="form-group">
          <label for="category">Category:</label>
          <select id="category">
            <option value="">Any Category</option>
            <!-- Categories will be loaded dynamically -->
          </select>
        </div>
        <div class="form-group">
          <label for="difficulty">Difficulty:</label>
          <select id="difficulty">
            <option value="">Any Difficulty</option>
            <option value="easy">Easy</option>
            <option value="medium">Medium</option>
            <option value="hard">Hard</option>
          </select>
        </div>
        <br />
        <button id="start-quiz-btn">Start Quiz</button>
        <button id="reset-quiz-btn" style="background: #6c757d">Reset</button>
      </div>

      <div id="quiz-container"></div>
    </div>

    <script src="/js/quiz.js"></script>
  </body>
</html>
